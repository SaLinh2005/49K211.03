# Supabase project URL (example: https://xxxxx.supabase.co)
VITE_SUPABASE_URL="MY_SUPABASE_URL"

# Supabase Publishable Key from Project Settings > API (recommended)
VITE_SUPABASE_PUBLISHABLE_KEY="MY_SUPABASE_PUBLISHABLE_KEY"

# Optional fallback if your project still uses anon key
VITE_SUPABASE_ANON_KEY=""
